{
  "name": "doss-clone",
  "private": true,
  "version": "2.0.0",
  "description": "Next.js rebuild of the current doss.com homepage with a local reference mirror.",
  "scripts": {
    "dev": "node server.mjs",
    "next:dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "node server.mjs",
    "mirror": "node scripts/mirror-doss.mjs",
    "mirror:local": "node scripts/mirror-doss.mjs --rewrite-local",
    "serve:mirror": "node server.mjs"
  },
  "dependencies": {
    "lottie-web": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  }
}
