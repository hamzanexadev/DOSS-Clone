{
  "name": "doss-clone",
  "private": true,
  "version": "2.0.0",
  "description": "Static local mirror of doss.com for Netlify deployment.",
  "scripts": {
    "dev": "node server.mjs",
    "build": "node scripts/normalize-static-mirror.mjs",
    "start": "node server.mjs",
    "mirror": "node scripts/mirror-doss.mjs",
    "mirror:local": "node scripts/mirror-doss.mjs --rewrite-local",
    "serve:mirror": "node server.mjs"
  }
}
